generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  email        String    @unique
  name         String?
  image        String?
  emailVerified DateTime?
  passwordHash  String?
  role         UserRole  @default(USER)
  createdAt    DateTime  @default(now())

  accounts     Account[]
  sessions     Session[]
  profile            Profile?
  preferences        UserPreferences?
  follows            Follow[]
  savedEvents        SavedEvent[]
  venueMembers       VenueMember[]
  artistMembers      ArtistMember[]
  promoterMembers    PromoterMember[]
  eventClaims        EventClaim[]
  pageClaims         PageClaim[]
  platformConnections PlatformConnection[]
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
}

enum UserRole {
  ADMIN
  USER
}

model Profile {
  userId      String  @id
  displayName String
  avatarUrl   String?
  bio         String?
  website     String?
  phone       String?

  user User @relation(fields: [userId], references: [id])
}

model UserPreferences {
  userId         String  @id
  homeCity       String  @default("Cardiff")
  timezone       String  @default("Europe/London")
  marketingOptIn Boolean @default(false)

  user User @relation(fields: [userId], references: [id])
}

model Venue {
  id           String   @id @default(uuid())
  name         String
  slug         String   @unique
  addressLine1 String?
  addressLine2 String?
  city         String   @default("Cardiff")
  postcode     String?
  lat          Float?
  lng          Float?
  capacity     Int?
  contactEmail String?
  verified     Boolean  @default(false)
  createdAt    DateTime @default(now())

  events  Event[]
  members VenueMember[]
}

model Artist {
  id            String   @id @default(uuid())
  name          String
  slug          String   @unique
  genreTags     String[]
  bio           String?
  socials       Json?
  pressPhotoUrl String?
  verified      Boolean  @default(false)
  createdAt     DateTime @default(now())

  events  EventArtist[]
  members ArtistMember[]
}

model Promoter {
  id           String   @id @default(uuid())
  name         String
  slug         String   @unique
  contactEmail String?
  verified     Boolean  @default(false)
  createdAt    DateTime @default(now())

  events  Event[]
  members PromoterMember[]
}

model Event {
  id              String   @id @default(uuid())
  title           String
  slug            String   @unique
  description     String?
  startAt         DateTime
  endAt           DateTime?
  timezone        String   @default("Europe/London")
  venueId         String?
  promoterId      String?
  status          EventStatus   @default(DRAFT)
  visibility      EventVisibility @default(PUBLIC)
  heroImageUrl    String?
  posterImageUrl  String?
  genreTags       String[]
  ageRestriction  String?
  createdByUserId String?
  managedByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  venue     Venue?    @relation(fields: [venueId], references: [id])
  promoter  Promoter? @relation(fields: [promoterId], references: [id])
  artists   EventArtist[]
  tickets   TicketLink[]
  claims    EventClaim[]
  saves     SavedEvent[]
}

enum EventStatus {
  DRAFT
  SUBMITTED
  APPROVED
  PUBLISHED
  CANCELLED
  REJECTED
}

enum EventVisibility {
  PUBLIC
  UNLISTED
}

model EventArtist {
  eventId     String
  artistId    String
  billingOrder Int

  event  Event  @relation(fields: [eventId], references: [id])
  artist Artist @relation(fields: [artistId], references: [id])

  @@id([eventId, artistId])
}

model TicketLink {
  id           String   @id @default(uuid())
  eventId      String
  platform     String
  url          String
  priceText    String?
  currency     String   @default("GBP")
  lastCheckedAt DateTime?

  event Event @relation(fields: [eventId], references: [id])
}

model Follow {
  id         String   @id @default(uuid())
  userId     String
  entityType String
  entityId   String
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, entityType, entityId])
}

model SavedEvent {
  id        String   @id @default(uuid())
  userId    String
  eventId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id])
  event Event @relation(fields: [eventId], references: [id])

  @@unique([userId, eventId])
}

model PlatformEvent {
  id             String   @id @default(uuid())
  platform       String
  externalId     String
  externalUrl    String?
  rawJson        Json
  fingerprint    String
  lastSeenAt     DateTime @default(now())
  matchStatus    String
  matchedEventId String?
}

model PlatformConnection {
  id                    String   @id @default(uuid())
  userId                String
  platform              String
  accessTokenEncrypted  String
  refreshTokenEncrypted String?
  expiresAt             DateTime?
  scope                 String?
  meta                  Json?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model EventClaim {
  id              String    @id @default(uuid())
  eventId         String
  userId          String
  platform        String
  connectionId    String
  externalEventId String
  verifiedAt      DateTime  @default(now())
  revokedAt       DateTime?

  event Event @relation(fields: [eventId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@unique([eventId, platform, externalEventId])
}

model PageClaim {
  id         String    @id @default(uuid())
  entityType String
  entityId   String
  userId     String
  method     String
  status     String
  evidence   Json?
  createdAt  DateTime  @default(now())
  reviewedAt DateTime?

  user User @relation(fields: [userId], references: [id])
}

model VenueMember {
  venueId String
  userId  String
  role    String

  venue Venue @relation(fields: [venueId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@id([venueId, userId])
}

model ArtistMember {
  artistId String
  userId   String
  role     String

  artist Artist @relation(fields: [artistId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@id([artistId, userId])
}

model PromoterMember {
  promoterId String
  userId     String
  role       String

  promoter Promoter @relation(fields: [promoterId], references: [id])
  user     User     @relation(fields: [userId], references: [id])

  @@id([promoterId, userId])
}
